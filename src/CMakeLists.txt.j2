#-----------------------------------------------------------------------------------------------------------------------
# Target: {{ project.name }}
# Alias: {{ project.namespace }}::{{ project.name }}
# Type: {{ project.type }}
# Dependencies: {{ project.namespace }}::{{ project.name }}_headers
#-----------------------------------------------------------------------------------------------------------------------
{% if project.type == "Executable" %}
# Target definition
add_executable({{ project.name }})

# Target alias
add_executable({{ project.namespace }}::{{ project.name }} ALIAS {{ project.name }})
{% elif project.type == "Static Library" %}
# Target definition
add_library({{ project.name }} STATIC)

# Target alias
add_library({{ project.namespace }}::{{ project.name }} ALIAS {{ project.name }})
{% elif project.type == "Shared Library" %}
# Target definition
add_library({{ project.name }} SHARED)

# Target alias
add_library({{ project.namespace }}::{{ project.name }} ALIAS {{ project.name }})
{% endif %}

# Target sources
target_sources({{ project.name }}
    PRIVATE
        ${CMAKE_CURRENT_SOURCE_DIR}/{{ project.name }}.cpp
)

{% if project.type == "Static Library" or project.type == "Shared Library" %}
# Target dependencies
target_link_libraries({{ project.name }}
    PUBLIC
        {{ project.namespace }}::{{ project.name }}_headers
)
{% endif %}

{% if project.type == "Executable" %}
# Target installation
if(NOT CMAKE_SKIP_INSTALL_RULES)
    include(GNUInstallDirs)

    install(TARGETS {{ project.name }}
            RUNTIME COMPONENT {{ project.name }}
            DESTINATION ${CMAKE_INSTALL_BINDIR}
    )
endif()
{% elif project.type == "Static Library" or project.type == "Shared Library" %}
# Export configuration
include(GenerateExportHeader)

if(BUILD_SHARED_LIBS)
    # Export file name for a shared build
    set(EXPORT_HEADER_FILE export_shared.hpp)

    # Primary target properties
    set_target_properties({{ project.name }} PROPERTIES
            OUTPUT_NAME {{ project.name }}
            VERSION ${PROJECT_VERSION}
            SOVERSION ${PROJECT_VERSION_MAJOR}
            CXX_VISIBILITY_PRESET hidden
            VISIBILITY_INLINES_HIDDEN ON
    )

    # Define compile definitions
    target_compile_definitions({{ project.name }}
            PUBLIC
                $<$<NOT:$<BOOL:${BUILD_SHARED_LIBS}>>:{{ project.name|to_screaming_case }}_STATIC_DEFINE>
    )
else()
    # Export file name for a static build
    set(EXPORT_HEADER_FILE export_static.hpp)

    # Primary target properties
    set_target_properties({{ project.name }} PROPERTIES
            OUTPUT_NAME {{ project.name }}
            VERSION ${PROJECT_VERSION}
            SOVERSION ${PROJECT_VERSION_MAJOR}
            POSITION_INDEPENDENT_CODE ON
    )

    # A static build must see the STATIC_DEFINE guard from the generated export header
    target_compile_definitions({{ project.name }}
            PUBLIC
                {{ project.name|to_screaming_case }}_STATIC_DEFINE
    )
endif()

# Generate the export header into the build tree
generate_export_header({{ project.name }}
        EXPORT_FILE_NAME include/{{ project.name }}/${EXPORT_HEADER_FILE}
)

# Make the generated export header visible to this target and its consumers
target_include_directories({{ project.name }}
    PUBLIC
        $<BUILD_INTERFACE:${CMAKE_CURRENT_BINARY_DIR}/include>
        $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>
)

if(NOT CMAKE_SKIP_INSTALL_RULES)
    include(GNUInstallDirs)

    # Install the library target (Conan/CMakeDeps provides the config + targets files)
    install(TARGETS {{ project.name }} {{ project.name }}_headers
            RUNTIME COMPONENT {{ project.name }}
            LIBRARY COMPONENT {{ project.name }}
            NAMELINK_COMPONENT {{ project.name }}
            ARCHIVE COMPONENT {{ project.name }}
            INCLUDES DESTINATION ${CMAKE_INSTALL_INCLUDEDIR})

    # Install the generated export header
    install(FILES ${CMAKE_CURRENT_BINARY_DIR}/include/{{ project.name }}/${EXPORT_HEADER_FILE}
            COMPONENT {{ project.name }}
            DESTINATION ${CMAKE_INSTALL_INCLUDEDIR}/{{ project.name }})
endif()
{% endif %}
